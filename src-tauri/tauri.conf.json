{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StreakStrike",
  "version": "0.1.0",
  "identifier": "com.streakstrike.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3003",
    "beforeBuildCommand": "npm run build:desktop:web",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "StreakStrike",
        "width": 1200,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "visible": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
